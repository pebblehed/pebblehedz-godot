# Pebble Hedz editor baseline.
# Repository-local settings take precedence over personal editor defaults.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.gd]
indent_style = tab
indent_size = 4

[*.tscn]
indent_style = tab
indent_size = 4

[*.godot]
indent_style = tab
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.json]
indent_style = tab
indent_size = 4
